# ============================================================
# Cloud Burst Detection System — Environment Variables
# ============================================================

# --- MySQL Database (XAMPP) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=hello
DB_NAME=weather_system

# --- Flask ---
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=cloudburst_secret_key_change_in_production_2024

# --- Visual Crossing Weather API ---
VISUAL_CROSSING_API_KEY=W9RFTTVBK9P2P4C5JVB376KVU

# --- Gmail SMTP (for email alerts) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
ALERT_FROM_EMAIL=your_gmail_address@gmail.com
ALERT_TO_EMAIL=recipient_email@gmail.com

# --- Twilio (for SMS alerts) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_TO_NUMBER=+91XXXXXXXXXX

# --- PDF Reports ---
REPORTS_DIR=reports

# --- Data ---
DATA_DIR=data
HISTORICAL_CSV=data/historical_raw.csv